generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  hashedPassword String?
  image          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Profile
  height         Float?
  weight         Float?
  age            Int?
  gender         String?
  activityLevel  String?
  goal           String?

  // Dietary preferences
  dietType       String?
  allergies      String?
  intolerances   String?

  sessions       Session[]
  foodEntries    FoodEntry[]
  dailySummaries DailySummary[]
  healthData     HealthData[]
  aiInsights     AIInsight[]
  waterEntries   WaterEntry[]
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  expiresAt    DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FoodEntry {
  id          String   @id @default(cuid())
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  description String
  mealType    String

  foodName    String?
  quantity    String?

  calories    Float?
  protein     Float?
  carbs       Float?
  fat         Float?
  fiber       Float?
  sugar       Float?
  sodium      Float?

  confidence  Float?
  aiAnalysis  String?

  imageUrl    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model DailySummary {
  id        String   @id @default(cuid())
  userId    String
  date      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  totalCalories Float  @default(0)
  totalProtein  Float  @default(0)
  totalCarbs    Float  @default(0)
  totalFat      Float  @default(0)
  totalFiber    Float  @default(0)
  totalWater    Float  @default(0)

  qualityScore  Float?
  aiSummary     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model HealthData {
  id        String   @id @default(cuid())
  userId    String
  date      String
  createdAt DateTime @default(now())

  steps        Int?
  activeEnergy Float?
  weight       Float?
  heartRate    Float?
  sleepHours   Float?

  source       String  @default("manual")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model WaterEntry {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())
  amount    Float

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model AIInsight {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())

  type      String
  title     String
  content   String
  category  String?
  priority  Int      @default(0)
  isRead    Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
