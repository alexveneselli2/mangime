# ---- Server ----
# Port is provided by Render automatically; defaults to 3000 locally
PORT=3000
NODE_ENV=development

# Public base URL of the app (used in password-reset links). On Render set to your service URL.
APP_URL=http://localhost:3000

# ---- Database (shared "stresstest" Postgres) ----
# Full connection string. On Render, use the Internal Database URL.
DATABASE_URL=postgresql://user:password@host:5432/stresstest
# Dedicated schema for NutrIA inside the shared database (isolation).
DB_SCHEMA=nutria
# Set to "true" only if your DB connection requires SSL (most managed Postgres do).
DATABASE_SSL=true

# ---- Sessions ----
# Long random string. Generate with: openssl rand -base64 48
SESSION_SECRET=change-me-to-a-long-random-string

# ---- Anthropic (server-side only) ----
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Email (Resend) ----
RESEND_API_KEY=re_...
# Verified sender address in your Resend account.
EMAIL_FROM=NutrIA <onboarding@resend.dev>
